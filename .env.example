APIFY_TOKEN=apify_api_xxx
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-opus-4-7
APIFY_ACTOR=apimaestro/linkedin-profile-posts
APIFY_PROFILE_ACTOR=supreme_coder/linkedin-profile-scraper
POSTS_LIMIT=30

# Supabase (BDD multi-utilisateurs)
SUPABASE_URL=https://zcxaxwqkswuefzlzpgvi.supabase.co
SUPABASE_ANON_KEY=eyJ...  # clé anon/publishable du projet

# Zernio (publication LinkedIn) — clé serveur uniquement, jamais côté front
ZERNIO_API_KEY=sk_xxx

# OpenAI (génération d'images — GPT Image 2)
OPENAI_API_KEY=sk-xxx

# Recherche web pendant la génération d'idées/posts (outil serveur Anthropic).
# Désactivée par défaut (coût + latence en plus). Mettre "true" pour activer.
ENABLE_WEB_SEARCH=false
WEB_SEARCH_MAX_USES=3  # nb max de recherches web par génération (plafond de coût)

# Agent de qualification Instagram — transport ManyChat (ALE-195/201)
MANYCHAT_API_TOKEN=          # token API ManyChat (envoi sortant des DM)
MANYCHAT_WEBHOOK_SECRET=     # secret partagé vérifié sur le webhook entrant (fail-closed)
IG_OWNER_USER_ID=            # user_id Supabase propriétaire du compte IG (v1 mono-compte)
